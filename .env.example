APP_ENV=production
STRICT_STARTUP_VALIDATION=true
LOG_LEVEL=INFO
TASK_MGMT_V1=true
TASK_TOOL_CALLING_V1=true
SCHEDULER_SECRET=replace-with-shared-secret
CLOUD_TASKS_PROJECT_ID=your-gcp-project-id
CLOUD_TASKS_LOCATION=us-central1
CLOUD_TASKS_QUEUE=event-dispatch
CLOUD_RUN_URL=https://your-cloud-run-url
CLOUD_TASKS_DISPATCH_URL=https://your-cloud-run-url/agent/events/execute
GOOGLE_API_KEY=your-gemini-api-key
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_AGENT_NAME=intentive-voice-agent
LIVEKIT_STT_MODEL=deepgram/nova-3
LIVEKIT_STT_LANGUAGE=en
LIVEKIT_TTS_MODEL=cartesia/sonic-3
LIVEKIT_TTS_VOICE=9626c31c-bec5-4cca-baa8-f8ba9e84c8bc
VOICE_DEBUG=false
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
